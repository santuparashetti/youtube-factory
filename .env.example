# YouTube Factory — Environment Configuration
# Copy this file to .env and fill in your API keys.
#
# Required: at least one LLM provider key + TAVILY_API_KEY

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini          # gemini | anthropic | groq | ollama

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-haiku-4-5
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# ── Image Generation ──────────────────────────────────────────────────────────
IMAGE_PROVIDER=huggingface   # huggingface | gemini | pollinations
HF_TOKEN=                    # Required for some HuggingFace models
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image

# ── Text-to-Speech ────────────────────────────────────────────────────────────
TTS_PROVIDER=Kokoro            # edge | kokoro | elevenlabs
# Kokoro (local neural TTS — no API key, downloads ~300 MB on first run):
#   uv pip install kokoro soundfile && apt install espeak-ng
KOKORO_VOICE=am_michael
KOKORO_SPEED=0.85

# ── WhisperX Forced Alignment ─────────────────────────────────────────────────
WHISPERX_ENABLED=false       # true to enable word-level subtitle alignment
WHISPERX_DEVICE=cpu          # cpu | cuda

# ── Video Settings ────────────────────────────────────────────────────────────
IMAGE_WIDTH=1280
IMAGE_HEIGHT=720
RENDER_PROFILE=balanced      # draft | balanced | cinematic | premium

# ── Background Music ──────────────────────────────────────────────────────────
BGM_ENABLED=false
BGM_CATEGORY=auto

# ── Runtime ───────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=60
