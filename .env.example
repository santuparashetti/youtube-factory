# YouTube Factory — Environment Configuration
# Copy this file to .env and fill in your API keys.
#
# Required: at least one LLM provider key + TAVILY_API_KEY

# ------------------------------------------------------------------
# API Keys
# ------------------------------------------------------------------
# HF_TOKEN=hf_vBVwLYMi...inQRIovGmR
# GEMINI_API_KEY=AQ.Ab8RN6L7qx1_....EjEUytoVNEiQ
# TAVILY_API_KEY=tvly-dev-228ChL-MJM3I7An....xhaOTBF0XcO
# GROQ_API_KEY=gsk_TsYX7yIWnbjcRB2A8ha....QMbncwAY584
# ANTHROPIC_API_KEY=sk-or-v1-6f9100894b....3d89b93866281
# CARTESIA_API_KEY=sk_car_EwuVvUg9...KnbCgW
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini          # gemini | anthropic | groq | ollama

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-haiku-4-5
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ------------------------------------------------------------------
# Hugging Face LLM
# ------------------------------------------------------------------

LLM_PROVIDER=huggingface
HF_LLM_PROVIDER=deepinfra
HF_LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
HF_LLM_TIMEOUT=60
HF_LLM_MAX_RETRIES=3

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# ── Image Generation ──────────────────────────────────────────────────────────
IMAGE_PROVIDER=huggingface   # huggingface | gemini | pollinations
HF_TOKEN=                    # Required for some HuggingFace models

# Tier 1 — default / first-pass (cheap, fast)
IMAGE_MODEL_TIER1_ID=black-forest-labs/FLUX.1-schnell
IMAGE_MODEL_TIER1_PROVIDER=auto        # auto | hf-inference | fireworks-ai | featherless-ai | together

# Tier 2 — first escalation (quality)
IMAGE_MODEL_TIER2_ID=Qwen/Qwen-Image
IMAGE_MODEL_TIER2_PROVIDER=auto

# Tier 3 — final escalation (premium, last resort)
IMAGE_MODEL_TIER3_ID=black-forest-labs/FLUX.1-dev
IMAGE_MODEL_TIER3_PROVIDER=auto

GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image

# ── Text-to-Speech ────────────────────────────────────────────────────────────
# Provider-agnostic voice profile — all narration references this instead of
# provider-specific knobs. New styles only require a registry entry.
VOICE_PROFILE=atma_theory

TTS_PROVIDER=Kokoro            # edge | kokoro | cartesia
# Kokoro (local neural TTS — no API key, downloads ~300 MB on first run):
#   uv pip install kokoro soundfile && apt install espeak-ng
KOKORO_VOICE=am_michael
KOKORO_SPEED=0.85

# Cartesia (premium cloud TTS — documentary / spiritual narration)
# Install: uv pip install cartesia
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-3.5
CARTESIA_VOICE_ID=
CARTESIA_SPEED=0.84
CARTESIA_OUTPUT_FORMAT=wav
CARTESIA_TIMEOUT=60
CARTESIA_MAX_CHARS=2000
CARTESIA_CACHE_ENABLED=true
CARTESIA_PRONUNCIATION_DICT_ID=
CARTESIA_SAMPLE_RATE=44100
CARTESIA_EMOTION=calm

# ── TTS Analytics & Cost Tracking ────────────────────────────────────────────
TTS_ANALYTICS_ENABLED=true
TTS_COST_TRACKING=true
TTS_LOG_PER_SCENE=true
TTS_SUMMARY_ENABLED=true
TTS_VERIFY_CACHE=true

# Cartesia pricing (loaded from configuration — not hardcoded)
CARTESIA_CREDITS_PER_CHARACTER=0
CARTESIA_CREDITS_PER_REQUEST=0
CARTESIA_USD_PER_CREDIT=0

# ── Pipeline Quality Gates ────────────────────────────────────────────────────
STOP_ON_QUALITY_GATE_FAILURE=true

# ── WhisperX Forced Alignment ─────────────────────────────────────────────────
WHISPERX_ENABLED=false       # true to enable word-level subtitle alignment
WHISPERX_DEVICE=cpu          # cpu | cuda

# ── Video Settings ────────────────────────────────────────────────────────────
IMAGE_WIDTH=1280
IMAGE_HEIGHT=720
RENDER_PROFILE=balanced      # draft | balanced | cinematic | premium

# ── Background Music ──────────────────────────────────────────────────────────
BGM_ENABLED=false
BGM_CATEGORY=auto           # auto | spiritual | meditation | cinematic_ambient | ...
BGM_LIBRARY_PATH=workspace/music
BGM_VOLUME=0.30             # BGM level during silence (0.0–1.0)
BGM_DUCK_FLOOR=0.04         # minimum BGM level during narration
BGM_DUCK_THRESHOLD=0.008    # amplitude threshold for ducking onset
BGM_DUCK_RATIO=8.0          # sidechain compressor ratio
BGM_DUCK_ATTACK_MS=15       # V2 legacy attack — overridden by V3 adaptive (180 ms)
BGM_DUCK_RELEASE_MS=350     # V2 legacy release — overridden by V3 adaptive (1800 ms)
BGM_FADE_IN_SECONDS=1.5
BGM_FADE_OUT_SECONDS=2.5
BGM_RANDOM_TRACK=true
BGM_VAD_ENABLED=true
BGM_PHRASE_GAP_MS=300       # V2 agate hold (ms); replaced by BGM_HOLD_AFTER_SPEECH_MS in V3

# ── BGM V3: Adaptive State-Machine Mixing ────────────────────────────────────
# Cinematic ducking: music stays down through breaths/commas/dramatic pauses.
# Only genuine long silence (>2.5 s) raises music. No pumping.
BGM_ADAPTIVE_MIXING=true
BGM_HOLD_AFTER_SPEECH_MS=2200      # hold music ducked this long after speech ends
BGM_LONG_SILENCE_THRESHOLD_MS=2500 # silence longer than this = MUSIC_FEATURE state
BGM_LONG_SILENCE_MS=2500           # review rule threshold (kept for backward compat)
BGM_NARRATION_LEVEL_LUFS=-30.0     # target narration LUFS (for review/debug)
BGM_MUSIC_LEVEL_LUFS=-17.0         # target music LUFS during silence
BGM_TRANSITION_CURVE=ease_in_out

# ── Image Review (Vision Quality Gate) ───────────────────────────────────────
# Enable AI-powered per-scene image quality review using MiniCPM-V 2.6 (~10 GB).
# When enabled, the Local AI Model Manager automatically downloads and manages
# the vision model. Leave false to skip (lightweight mode, no model required).
IMAGE_REVIEW_ENABLED=false
VISION_REVIEW_PROVIDER=local            # local | mock
VISION_MAX_CONCURRENCY=5                # max concurrent vision QA requests (1-100)
VISION_REVIEW_LOCAL_MODEL=minicpm_v2_6  # switchable via config only
IMAGE_REVIEW_MIN_SCORE=90
IMAGE_REVIEW_CONFIDENCE=80
IMAGE_REVIEW_MAX_ATTEMPTS=3
IMAGE_REVIEW_AUTO_REMEDIATE=true
IMAGE_REVIEW_DEBUG=false

# ── Image Review — Anatomy hard-floor defense-in-depth (0–100 scale) ───────────
IMAGE_REVIEW_ANATOMY_FLOOR_THRESHOLD=6.0
IMAGE_REVIEW_ANATOMY_QUALITY_CAP=6.0

# ── Image Generation — Escalation Policy (0–10 scale) ─────────────────────────
IMAGE_ESCALATION_TARGET_QUALITY_SCORE=9.2
IMAGE_ESCALATION_RETRY_THRESHOLD=8.5
IMAGE_ESCALATION_PREMIUM_MODEL_THRESHOLD=8.5
IMAGE_ESCALATION_MAX_PROMPT_REFINEMENTS=1
IMAGE_ESCALATION_MAX_MODEL_ESCALATIONS=2

# ── Runtime ───────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=60
